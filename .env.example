# Secrets template. Copy this to .env.local and fill in your own values:
#   cp .env.example .env.local
# .env.local is gitignored — never commit it with real secrets.

# From @BotFather (create your own bot) and your chat ID.
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Optional — only needed if the LLM matching tier is enabled (see config/matcher.yml).
ANTHROPIC_API_KEY=

# Optional — only needed if companies_source is 'notion' (see config/matcher.yml).
# Create an internal integration at https://www.notion.so/my-integrations,
# then share your Companies database with it.
NOTION_TOKEN=
